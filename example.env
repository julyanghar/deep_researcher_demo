# Example environment for deep_researcher_demo.
# Replace MODEL with the model served by your OpenAI-compatible endpoint.

OPENAI_BASE_URL=http://localhost:30000/v1
OPENAI_API_KEY=dummy
MODEL=Qwen3-30B-A3B-Instruct-2507

# Role-specific models are optional. If omitted, MODEL is used for every role.
# SUPERVISOR_MODEL=your-model-name
# RESEARCHER_MODEL=your-model-name
# SUMMARY_MODEL=your-model-name
# FINAL_MODEL=your-model-name

# DeepSearchQA autorater settings. Report generation still uses OPENAI_* above;
# scoring uses this DashScope-compatible endpoint and model.
JUDGE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
JUDGE_API_KEY=
JUDGE_MODEL=deepseek-v3.2

# Search provider: duckduckgo or tavily. Tavily requires TAVILY_API_KEY below.
SEARCH_PROVIDER=duckduckgo
# export SEARCH_PROVIDER=tavily
# export TAVILY_API_KEY=your-tavily-api-key


MAX_ITERATIONS=3
MAX_FOLLOWUPS=3
MAX_QUERIES_PER_RESEARCHER=3
MAX_CONCURRENCY=3
MAX_RESULTS=5

# DuckDuckGo first returns search snippets, then fetches each result page and
# passes extracted page text to the researcher. Failed fetches fall back to snippets.
FETCH_WEBPAGES=1
MAX_CONTENT_CHARS=12000
FETCH_TIMEOUT=10
FETCH_CONCURRENCY=8

OUTPUT=outputs/example_report.md

# Required when SEARCH_PROVIDER=tavily.
# TAVILY_API_KEY=
